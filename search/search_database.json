r , public :: fscale_xf = & [ 1.0e+04_wp , 1.0e+04_wp , 1.0e+04_wp , 1.0e+02_wp , 1.0e+02_wp , 1.0e+02_wp ] type , public :: patch_point !! a CR3BP Halo state, to be used as !! an initial guess for the full force model. real ( wp ) :: t = zero !! Time from Periapse (days from periapsis) real ( wp ), dimension ( 6 ) :: rv = zero !! Rx (km) !! Ry (km) !! Rz (km) !! Vx (km/s) !! Vy (km/s) !! Vz (km/s) [moon-centered earth-moon rotating frame] end type patch_point end module parameters_module","tags":"","url":"sourcefile/parameters_module.f90.html"}]}